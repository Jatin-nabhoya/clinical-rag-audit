# venv
.clinical-rag-audit
clinical-rag-audit/

# Data — too big for git
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/processed/eval_questions.jsonl

# Vector store (binary FAISS indexes — too large for git)
data/vector_store/

# Model cache
*.bin
*.safetensors
.cache/

# Results — Phase 4+ outputs are committed
!results/.gitkeep

# Secrets
.env
*.key

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db